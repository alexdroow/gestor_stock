{
  "$schema": "https://schema.tauri.app/config/1",
  "package": {
    "productName": "Launcher Admin Sucree",
    "version": "0.1.0"
  },
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "../src",
    "distDir": "../src"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "window": {
        "create": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["msi"],
      "identifier": "com.sucree.launcheradmin",
      "icon": [
        "icons/icon.ico"
      ]
    },
    "windows": [
      {
        "label": "launcher",
        "title": "Launcher Admin Sucree",
        "width": 980,
        "height": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
